{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post",
    "description": "Blog articles and guides"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "category": {
      "type": "string"
    },
    "readTime": {
      "type": "string"
    },
    "publishDate": {
      "type": "date"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "imageUrl": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}