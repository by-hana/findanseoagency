---
import '../styles/global.css';
import { getGlobal } from '../lib/strapi';

interface Props {
  title?: string;
  description?: string;
  activeNav?: string;
}

const { title = 'FindAnSEOAgency', description = '', activeNav = '' } = Astro.props;

let global: any = null;
try {
  global = await getGlobal();
} catch (e) {
  console.warn('Could not fetch global settings from Strapi');
}

const siteName = global?.siteName || 'FindAnSEOAgency';
const navLinks = global?.navLinks || [
  { label: 'Agencies', href: '/' },
  { label: 'AI Optimization', href: '/ai-optimization' },
  { label: 'SEO Basics', href: '/seo-agencies' },
  { label: 'Blog', href: '/blog' },
];
const footerTagline = global?.footerTagline || 'Curating the world\'s most sophisticated digital search partners for the intelligence era.';
const footerColumns = global?.footerColumns || [];
const copyrightText = global?.copyrightText || `\u00A9 ${new Date().getFullYear()} FindAnSEOAgency`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&f[]=satoshi@300,400,500,600,700,900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-cream text-ink font-body antialiased overflow-x-hidden">

  <!-- ═══════ SEARCH OVERLAY (global) ═══════ -->
  <div id="search-overlay" class="fixed inset-0 z-[200] bg-dark/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500"></div>

  <!-- Vertical search pill — fixed right edge -->
  <div id="search-pill" class="fixed right-8 md:right-10 top-1/2 -translate-y-1/2 z-[201] cursor-pointer" role="button" aria-label="Open search">
    <div id="search-collapsed" class="flex flex-col items-center gap-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-full px-3 py-6 transition-all duration-500 hover:border-orange/40 hover:bg-white/10">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,95,0,0.8)" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
      <span class="font-mono text-[9px] tracking-[0.25em] uppercase text-white/50" style="writing-mode: vertical-lr;">Search</span>
    </div>
  </div>

  <!-- Expanded search — centered -->
  <div id="search-expanded" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[202] w-[90vw] max-w-2xl opacity-0 pointer-events-none scale-95 transition-all duration-500 ease-[cubic-bezier(0.19,1,0.22,1)]">
    <div class="bg-dark-elevated/90 backdrop-blur-2xl border border-dark-border rounded-2xl p-6 shadow-[0_0_80px_rgba(255,95,0,0.08)]">
      <div class="flex items-center gap-4">
        <svg class="text-orange flex-shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
        <input
          id="search-input"
          class="flex-grow py-2 text-lg font-body text-on-dark placeholder:text-on-dark-faint bg-transparent focus:outline-none"
          placeholder="Search by specialty, location, or agency name..."
          type="text"
          autocomplete="off"
        />
        <button class="bg-orange hover:bg-orange-dim text-white px-7 py-3 rounded-full font-display text-sm font-500 transition-all duration-300 cursor-pointer whitespace-nowrap hover:shadow-[0_0_30px_rgba(255,95,0,0.3)]">
          Search
        </button>
      </div>
      <div class="flex items-center gap-4 mt-4 ml-10 font-mono text-[10px] tracking-[0.15em] uppercase text-on-dark-faint">
        <span>Popular:</span>
        <a href="#" class="text-orange/60 hover:text-orange cursor-pointer transition-colors duration-200">AI SEO</a>
        <span class="text-dark-border">/</span>
        <a href="#" class="text-orange/60 hover:text-orange cursor-pointer transition-colors duration-200">Enterprise</a>
        <span class="text-dark-border">/</span>
        <a href="#" class="text-orange/60 hover:text-orange cursor-pointer transition-colors duration-200">LLM Optimization</a>
      </div>
    </div>
    <p class="text-center font-mono text-[10px] text-on-dark-faint mt-4 tracking-wider">ESC to close</p>
  </div>

  <!-- ═══════ NAV ═══════ -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-[100] mix-blend-difference transition-all duration-500">
    <div id="nav-inner" class="flex justify-between items-center px-6 md:px-10 py-8 md:py-10 w-full transition-all duration-500">
      <a href="/" class="font-display text-base font-600 tracking-tight text-white cursor-pointer uppercase">
        {siteName}
      </a>
      <div class="hidden md:flex items-center gap-8 font-body text-[13px] font-500 text-white/70">
        {navLinks.map((link: any) => (
          <a
            class={`cursor-pointer transition-opacity duration-300 hover:opacity-100 ${activeNav === link.href ? 'opacity-100' : 'opacity-60'}`}
            href={link.href}
          >
            {link.label}
          </a>
        ))}
      </div>
      <button id="nav-search-btn" type="button" class="font-mono text-[10px] tracking-[0.2em] uppercase text-white/60 hover:text-white/100 cursor-pointer transition-opacity duration-300 bg-transparent border-none">
        Search
      </button>
    </div>
  </nav>

  <!-- ═══════ PAGE CONTENT (blurable) ═══════ -->
  <div id="main-content" class="transition-[filter] duration-500">
    <slot />

    <!-- ═══════ FOOTER ═══════ -->
    <footer class="bg-dark text-on-dark relative overflow-hidden grain">
      <!-- Giant background text -->
      <div class="absolute top-8 left-0 right-0 overflow-hidden pointer-events-none select-none z-0" aria-hidden="true">
        <div class="font-display text-[clamp(6rem,18vw,14rem)] font-700 text-dark-elevated leading-none tracking-tight whitespace-nowrap">
          FIND AN SEO AGENCY
        </div>
      </div>

      <div class="relative z-[2] pt-40 pb-10 px-6 md:px-10">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-20">
          <div class="md:col-span-5">
            <p class="text-on-dark-muted text-sm leading-relaxed max-w-sm">{footerTagline}</p>
            <div class="flex gap-3 mt-8">
              <a class="w-10 h-10 rounded-full bg-dark-elevated flex items-center justify-center text-on-dark-muted hover:text-orange hover:bg-dark-border cursor-pointer transition-all duration-300" href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a class="w-10 h-10 rounded-full bg-dark-elevated flex items-center justify-center text-on-dark-muted hover:text-orange hover:bg-dark-border cursor-pointer transition-all duration-300" href="#">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
          {footerColumns.map((col: any) => (
            <div class="md:col-span-2">
              <h5 class="font-mono text-[10px] tracking-[0.2em] uppercase text-on-dark-faint mb-6">{col.title}</h5>
              <ul class="space-y-3">
                {col.links.map((link: any) => (
                  <li>
                    <a class="text-on-dark-muted text-sm hover:text-orange cursor-pointer transition-colors duration-300" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-8 border-t border-dark-border">
          <p class="font-mono text-[10px] tracking-wider text-on-dark-faint">{copyrightText}</p>
          <p class="font-mono text-[10px] tracking-wider text-on-dark-faint">Built for the intelligence era</p>
        </div>
      </div>
    </footer>
  </div>

  <!-- ═══════ SEARCH PILL THEME SWITCH ═══════ -->
  <script>
    (function pillTheme() {
      const collapsed = document.getElementById('search-collapsed');
      const pill = document.getElementById('search-pill');
      if (!collapsed || !pill) return;

      const label = collapsed.querySelector('span');
      let isDark = true;

      // Dark section indicators: classes or inline styles that mean dark bg
      const darkIndicators = ['mesh-dark', 'bg-dark', 'bg-dark-elevated'];

      function check() {
        const rect = pill.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;

        pill.style.pointerEvents = 'none';
        pill.style.visibility = 'hidden';
        const behind = document.elementFromPoint(cx, cy);
        pill.style.pointerEvents = '';
        pill.style.visibility = '';

        let onDark = false;
        let el = behind;
        while (el && el !== document.body) {
          // Check class names for known dark patterns
          if (darkIndicators.some(cls => el!.classList.contains(cls))) {
            onDark = true;
            break;
          }
          // Also check computed background as fallback
          const bg = getComputedStyle(el!).backgroundColor;
          if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
            const m = bg.match(/\d+/g);
            if (m) {
              const brightness = (parseInt(m[0]) + parseInt(m[1]) + parseInt(m[2])) / 3;
              onDark = brightness < 80;
            }
            break;
          }
          el = el!.parentElement;
        }

        if (onDark === isDark) return;
        isDark = onDark;

        if (isDark) {
          collapsed.style.background = 'rgba(255,255,255,0.05)';
          collapsed.style.borderColor = 'rgba(255,255,255,0.1)';
          if (label) label.style.color = 'rgba(255,255,255,0.5)';
        } else {
          collapsed.style.background = 'rgba(0,0,0,0.05)';
          collapsed.style.borderColor = 'rgba(0,0,0,0.12)';
          if (label) label.style.color = 'rgba(0,0,0,0.4)';
        }
      }

      window.addEventListener('scroll', check, { passive: true });
      check();
    })();
  </script>

  <!-- ═══════ NAV SCROLL EFFECT ═══════ -->
  <script>
    (function navScroll() {
      const nav = document.getElementById('main-nav');
      const inner = document.getElementById('nav-inner');
      if (!nav || !inner) return;

      let scrolled = false;

      function check() {
        const isScrolled = window.scrollY > 60;
        if (isScrolled === scrolled) return;
        scrolled = isScrolled;

        if (scrolled) {
          // Glass card mode
          nav.style.mixBlendMode = 'normal';
          nav.style.top = '0.75rem';
          nav.style.left = '0.75rem';
          nav.style.right = '0.75rem';
          nav.style.borderRadius = '1rem';
          nav.style.background = 'rgba(11,11,11,0.7)';
          nav.style.backdropFilter = 'blur(20px) saturate(1.4)';
          nav.style.border = '1px solid rgba(255,255,255,0.08)';
          inner.style.padding = '0.75rem 1.5rem';
        } else {
          // Transparent mode
          nav.style.mixBlendMode = 'difference';
          nav.style.top = '0';
          nav.style.left = '0';
          nav.style.right = '0';
          nav.style.borderRadius = '0';
          nav.style.background = 'transparent';
          nav.style.backdropFilter = 'none';
          nav.style.border = 'none';
          inner.style.padding = '';
        }
      }

      window.addEventListener('scroll', check, { passive: true });
      check();
    })();
  </script>

  <!-- ═══════ SEARCH TOGGLE SCRIPT (global) ═══════ -->
  <script>
    (function searchToggle() {
      const pill = document.getElementById('search-pill');
      const collapsed = document.getElementById('search-collapsed');
      const expanded = document.getElementById('search-expanded');
      const overlay = document.getElementById('search-overlay');
      const mainContent = document.getElementById('main-content');
      const input = document.getElementById('search-input') as HTMLInputElement | null;
      if (!pill || !collapsed || !expanded || !overlay || !mainContent || !input) return;

      let isOpen = false;

      function open() {
        if (isOpen) return;
        isOpen = true;
        collapsed.style.opacity = '0';
        collapsed.style.pointerEvents = 'none';
        collapsed.style.transform = 'scale(0.8)';
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'auto';
        expanded.style.opacity = '1';
        expanded.style.pointerEvents = 'auto';
        expanded.style.transform = 'translate(-50%, -50%) scale(1)';
        mainContent.style.filter = 'blur(12px) brightness(0.5)';
        setTimeout(() => input.focus(), 300);
      }

      function close() {
        if (!isOpen) return;
        isOpen = false;
        collapsed.style.opacity = '1';
        collapsed.style.pointerEvents = 'auto';
        collapsed.style.transform = 'scale(1)';
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        expanded.style.opacity = '0';
        expanded.style.pointerEvents = 'none';
        expanded.style.transform = 'translate(-50%, -50%) scale(0.95)';
        mainContent.style.filter = '';
        input.value = '';
      }

      collapsed.style.transition = 'opacity 0.4s, transform 0.4s, border-color 0.5s, background 0.5s';
      pill.addEventListener('click', open);
      overlay.addEventListener('click', close);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

      const navBtn = document.getElementById('nav-search-btn');
      if (navBtn) navBtn.addEventListener('click', open);
    })();
  </script>

</body>
</html>
