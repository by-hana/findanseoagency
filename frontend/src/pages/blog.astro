---
import Layout from '../layouts/Layout.astro';
import { getPageBySlug, getBlogPosts, getGlobal } from '../lib/strapi';

const page = await getPageBySlug('blog');
const posts = await getBlogPosts();
const global = await getGlobal();
const sections = page?.sections || {};

const featuredPost = posts?.find((p: any) => p.featured);
const regularPosts = posts?.filter((p: any) => !p.featured && p.imageUrl) || [];
const categories = sections.categories || ['All Insights', 'AI Optimization', 'SEO Basics', 'Agency Reviews', 'Industry News'];
---

<Layout title={page?.seoTitle} description={page?.seoDescription} activeNav="/blog">
  <main class="pt-32 pb-24 relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] hero-glow pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-6 relative">
      <!-- Header Section -->
      <header class="mb-16">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-12 h-[1px] bg-primary"></span>
          <span class="font-label text-xs font-bold tracking-[0.2em] text-primary uppercase">{page?.heroEyebrow}</span>
        </div>
        <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface mb-6 leading-[0.9]">
          {page?.heroTitle} <br/><span class="text-primary">{page?.heroHighlight}</span>.
        </h1>
        <p class="max-w-2xl text-on-surface-variant text-lg leading-relaxed">{page?.heroDescription}</p>
      </header>

      <!-- Category Filter Bar -->
      <div class="mb-12 overflow-x-auto">
        <div class="flex items-center gap-3 pb-4">
          {categories.map((cat: string, i: number) => (
            <button class={`px-6 py-2 rounded-full font-label text-xs font-semibold whitespace-nowrap ${i === 0 ? 'bg-on-surface text-surface' : 'bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high transition-colors'}`}>
              {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Featured Post -->
      {featuredPost && (
        <section class="mb-24">
          <article class="relative group bg-surface-container-low rounded-xl overflow-hidden shadow-sm flex flex-col lg:flex-row">
            <div class="lg:w-3/5 overflow-hidden h-96 lg:h-auto">
              <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt={featuredPost.title} src={featuredPost.imageUrl} />
            </div>
            <div class="lg:w-2/5 p-8 lg:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-6">
                <span class="px-3 py-1 bg-primary/10 text-primary rounded-full font-label text-[10px] font-bold tracking-wider uppercase">{featuredPost.category}</span>
                <span class="text-on-surface-variant font-label text-[10px] font-medium tracking-wider uppercase">{featuredPost.readTime}</span>
              </div>
              <h2 class="font-headline text-3xl md:text-4xl font-bold tracking-tight text-on-surface mb-6 group-hover:text-primary transition-colors">
                {featuredPost.title}
              </h2>
              <p class="text-on-surface-variant mb-8 leading-relaxed">{featuredPost.excerpt}</p>
              <div class="flex items-center gap-4">
                <a href="/ai-optimization" class="bg-primary text-on-primary px-8 py-3 rounded-full font-label text-xs font-bold tracking-widest uppercase flex items-center gap-2 group/btn">
                  Read Article
                  <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">arrow_forward</span>
                </a>
              </div>
            </div>
          </article>
        </section>
      )}

      <!-- Blog Feed Grid -->
      {regularPosts.length > 0 && (
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {regularPosts.map((post: any) => (
            <article class="flex flex-col h-full bg-surface-container-lowest rounded-lg p-6 hover:shadow-xl transition-all duration-300 border border-outline-variant/10">
              {post.imageUrl && (
                <div class="rounded-lg overflow-hidden mb-6 aspect-video">
                  <img class="w-full h-full object-cover" alt={post.title} src={post.imageUrl} />
                </div>
              )}
              <div class="mb-4">
                <span class="font-label text-[10px] font-bold tracking-[0.15em] text-primary uppercase">{post.category}</span>
              </div>
              <h3 class="font-headline text-xl font-bold text-on-surface mb-3 flex-grow">{post.title}</h3>
              <p class="text-on-surface-variant text-sm line-clamp-3 mb-6 leading-relaxed">{post.excerpt}</p>
              <div class="pt-6 border-t border-outline-variant/10 flex items-center justify-between">
                <span class="text-on-surface-variant font-label text-[10px] uppercase font-semibold">
                  {post.publishDate ? new Date(post.publishDate).toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' }) : ''}
                </span>
                <a class="text-primary font-label text-[10px] uppercase font-bold tracking-widest hover:underline" href="#">Read More</a>
              </div>
            </article>
          ))}
        </section>
      )}

      <!-- Newsletter Callout -->
      <section class="mt-24 bg-surface-container-high rounded-xl p-8 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 blur-[100px] rounded-full"></div>
        <div class="md:w-1/2 z-10">
          <h3 class="font-headline text-3xl md:text-4xl font-bold tracking-tight mb-4" set:html={(global?.newsletterTitle || 'Stay ahead of the Algorithm.').replace('Algorithm', '<span class="text-primary">Algorithm</span>')} />
          <p class="text-on-surface-variant leading-relaxed">{global?.newsletterDescription || 'Get the weekly memo on SEO shifts and AI integration directly from our research team.'}</p>
        </div>
        <div class="md:w-1/2 w-full z-10">
          <form class="flex flex-col sm:flex-row gap-4">
            <input class="flex-grow bg-surface border-none rounded-full px-8 py-4 focus:ring-2 focus:ring-primary text-sm font-medium" placeholder={global?.newsletterPlaceholder || 'Enter your work email'} type="email" />
            <button class="bg-primary text-on-primary px-10 py-4 rounded-full font-label text-xs font-bold tracking-widest uppercase hover:opacity-90 transition-opacity">
              Subscribe
            </button>
          </form>
          <p class="mt-4 text-[10px] font-label text-on-surface-variant uppercase tracking-wider text-center sm:text-left">Join 15,000+ technical marketers.</p>
        </div>
      </section>
    </div>
  </main>
</Layout>
