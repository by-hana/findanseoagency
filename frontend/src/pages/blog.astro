---
import Layout from '../layouts/Layout.astro';
import { getPageBySlug, getBlogPosts, getGlobal } from '../lib/strapi';

const page = await getPageBySlug('blog');
const posts = await getBlogPosts();
const global = await getGlobal();
const sections = page?.sections || {};

const featuredPost = posts?.find((p: any) => p.featured);
const regularPosts = posts?.filter((p: any) => !p.featured && p.imageUrl) || [];
const categories = sections.categories || ['All Insights', 'AI Optimization', 'SEO Basics', 'Agency Reviews', 'Industry News'];
---

<Layout title={page?.seoTitle} description={page?.seoDescription} activeNav="/blog">
  <main>

    <!-- ═══════ HERO — Dark mesh ═══════ -->
    <section class="relative min-h-[70vh] flex items-end mesh-dark grain overflow-hidden">
      <div class="absolute top-[30%] right-[15%] w-48 h-48 bg-orange/5 blur-[100px] rounded-full float pointer-events-none"></div>

      <div class="relative z-[3] px-6 md:px-10 pb-16 md:pb-20 max-w-3xl">
        {page?.heroEyebrow && (
          <span class="section-label text-orange-light mb-4 block">{page.heroEyebrow}</span>
        )}
        <h1 class="font-display text-[clamp(2.5rem,6vw,5.5rem)] font-700 tracking-tight leading-[0.9] text-on-dark">
          {page?.heroTitle}<br/>
          {page?.heroHighlight && (
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange to-orange-light">{page.heroHighlight}</span>
          )}
        </h1>
        <p class="text-on-dark-muted text-lg leading-relaxed mt-6 max-w-xl">{page?.heroDescription}</p>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-cream to-transparent z-[2]"></div>
    </section>


    <!-- ═══════ FILTER — Horizontal scroll ═══════ -->
    <div class="px-6 md:px-10 py-8 overflow-x-auto">
      <div class="flex items-center gap-3">
        {categories.map((cat: string, i: number) => (
          <button class={`px-5 py-2.5 rounded-full font-mono text-[10px] tracking-[0.15em] uppercase whitespace-nowrap cursor-pointer transition-all duration-300 ${
            i === 0
              ? 'bg-dark text-white'
              : 'bg-cream-dark text-ink-muted hover:text-orange hover:bg-orange-subtle'
          }`}>
            {cat}
          </button>
        ))}
      </div>
    </div>


    <!-- ═══════ FEATURED POST — Full bleed image ═══════ -->
    {featuredPost && (
      <section class="px-6 md:px-10 pb-16">
        <article class="relative min-h-[60vh] rounded-3xl overflow-hidden cursor-pointer group">
          <!-- Background image with duotone -->
          <img class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt={featuredPost.title} src={featuredPost.imageUrl} />
          <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/70 to-dark/20"></div>
          <div class="absolute inset-0 bg-orange/5 mix-blend-multiply"></div>

          <!-- Content anchored bottom-left -->
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-14 z-10">
            <div class="flex items-center gap-4 mb-5">
              <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-orange bg-orange/15 backdrop-blur px-3 py-1 rounded-full">{featuredPost.category}</span>
              <span class="font-mono text-[10px] tracking-wider text-white/50">{featuredPost.readTime}</span>
            </div>
            <h2 class="font-display text-3xl md:text-5xl font-700 tracking-tight text-white leading-[0.95] max-w-2xl group-hover:text-orange transition-colors duration-300">
              {featuredPost.title}
            </h2>
            <p class="text-white/60 text-base leading-relaxed mt-4 max-w-lg">{featuredPost.excerpt}</p>
            <div class="mt-8 flex items-center gap-3">
              <span class="font-display text-sm font-500 text-white">Read article</span>
              <svg class="text-orange group-hover:translate-x-2 transition-transform duration-300" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </article>
      </section>
    )}


    <!-- ═══════ POST GRID — Varied layout ═══════ -->
    {regularPosts.length > 0 && (
      <section class="px-6 md:px-10 pb-24">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          {regularPosts.map((post: any, i: number) => {
            const isLarge = i === 0;
            const span = isLarge ? 'md:col-span-7' : 'md:col-span-5';
            return (
              <article class={`${span} group cursor-pointer`}>
                {post.imageUrl && (
                  <div class={`relative overflow-hidden rounded-2xl ${isLarge ? 'aspect-[4/3]' : 'aspect-[3/2]'} mb-5`}>
                    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt={post.title} src={post.imageUrl} />
                    <div class="absolute inset-0 bg-orange/5 mix-blend-multiply"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-dark/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                  </div>
                )}
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-mono text-[10px] tracking-[0.2em] text-orange uppercase">{post.category}</span>
                  <span class="w-1 h-1 rounded-full bg-ink-faint"></span>
                  <span class="font-mono text-[10px] text-ink-muted">
                    {post.publishDate ? new Date(post.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : ''}
                  </span>
                </div>
                <h3 class={`font-display font-600 text-dark group-hover:text-orange transition-colors duration-300 ${isLarge ? 'text-2xl md:text-3xl' : 'text-xl'}`}>{post.title}</h3>
                <p class="text-ink-light text-sm line-clamp-2 mt-2 leading-relaxed">{post.excerpt}</p>
              </article>
            );
          })}
        </div>
      </section>
    )}


    <!-- ═══════ NEWSLETTER — Mesh dark ═══════ -->
    <section class="mesh-dark grain relative py-24 md:py-36 px-6 md:px-10 overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-orange/6 blur-[200px] rounded-full pointer-events-none pulse-glow"></div>

      <div class="relative z-[3] flex flex-col lg:flex-row items-start lg:items-end justify-between gap-12">
        <div class="lg:w-1/2">
          <span class="section-label text-orange-light mb-4 block">Stay connected</span>
          <h3 class="font-display text-4xl md:text-6xl font-700 tracking-tight text-on-dark leading-[0.9]">
            Stay ahead of the<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange to-orange-light">Algorithm.</span>
          </h3>
          <p class="text-on-dark-muted leading-relaxed mt-6 max-w-md">{global?.newsletterDescription || 'Get the weekly memo on SEO shifts and AI integration directly from our research team.'}</p>
        </div>
        <div class="lg:w-1/2 w-full">
          <div class="flex items-center bg-white/5 backdrop-blur-xl border border-white/10 rounded-full overflow-hidden hover:border-orange/30 transition-colors duration-500">
            <input
              class="flex-grow py-4 px-6 text-sm font-body text-on-dark placeholder:text-on-dark-faint bg-transparent focus:outline-none"
              placeholder={global?.newsletterPlaceholder || 'Enter your work email'}
              type="email"
            />
            <button class="bg-orange hover:bg-orange-dim text-white m-1.5 px-6 py-3 rounded-full font-display text-sm font-500 cursor-pointer transition-all duration-300 whitespace-nowrap hover:shadow-[0_0_30px_rgba(255,95,0,0.3)]">
              Subscribe
            </button>
          </div>
          <p class="mt-4 font-mono text-[10px] tracking-wider text-on-dark-faint ml-6">Join 15,000+ technical marketers.</p>
        </div>
      </div>
    </section>

  </main>
</Layout>
