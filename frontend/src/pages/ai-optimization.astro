---
import Layout from '../layouts/Layout.astro';
import { getPageBySlug } from '../lib/strapi';

const page = await getPageBySlug('ai-optimization');
const sections = page?.sections || {};
---

<Layout title={page?.seoTitle} description={page?.seoDescription} activeNav="/ai-optimization">
  <main class="pt-24 overflow-hidden">
    <!-- Hero Section -->
    <section class="relative px-6 py-20 md:py-32 max-w-7xl mx-auto">
      <div class="absolute -top-24 -left-48 w-96 h-96 atmospheric-glow rounded-full"></div>
      <div class="absolute top-48 -right-48 w-[32rem] h-[32rem] atmospheric-glow rounded-full"></div>
      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 space-y-8">
          {page?.heroEyebrow && (
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-secondary-container/30 border border-secondary/10">
              <span class="material-symbols-outlined text-sm text-primary">auto_awesome</span>
              <span class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-primary">{page.heroEyebrow}</span>
            </div>
          )}
          <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter leading-[1.05] text-on-surface">
            {page?.heroTitle} <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-container">{page?.heroHighlight}</span>
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">{page?.heroDescription}</p>
          <div class="flex flex-wrap gap-4 pt-4">
            {page?.heroPrimaryButtonText && (
              <a href={page.heroPrimaryButtonLink || '#'} class="px-8 py-4 bg-primary text-on-primary rounded-full font-label text-sm font-bold shadow-xl shadow-primary/10 hover:translate-y-[-2px] transition-transform">
                {page.heroPrimaryButtonText}
              </a>
            )}
            {page?.heroSecondaryButtonText && (
              <a href={page.heroSecondaryButtonLink || '/'} class="px-8 py-4 glass-card rounded-full font-label text-sm font-bold text-on-surface hover:bg-white/80 transition-colors">
                {page.heroSecondaryButtonText}
              </a>
            )}
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          {page?.heroImageUrl && (
            <div class="aspect-square rounded-lg overflow-hidden glass-card p-4 shadow-2xl">
              <img alt="AI GEO Optimization Visual" class="w-full h-full object-cover rounded-md" src={page.heroImageUrl} />
            </div>
          )}
          {page?.heroStatValue && (
            <div class="absolute -bottom-8 -left-8 p-6 glass-card rounded-lg shadow-xl max-w-[200px]">
              <p class="font-label text-[10px] text-primary font-bold uppercase tracking-widest mb-2">{page.heroStatLabel}</p>
              <p class="font-headline text-3xl font-bold">{page.heroStatValue}</p>
              <p class="text-[11px] text-on-surface-variant leading-tight">{page.heroStatDescription}</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- What is GEO Section -->
    {sections.whatIsGeo && (
      <section class="bg-surface-container-low py-24">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
            <div class="order-2 md:order-1 relative h-[500px] rounded-lg overflow-hidden group">
              <img alt="What is GEO" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={sections.whatIsGeo.imageUrl} />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low via-transparent to-transparent"></div>
            </div>
            <div class="order-1 md:order-2 space-y-6">
              <h2 class="font-headline text-4xl font-bold tracking-tight">{sections.whatIsGeo.title}</h2>
              <p class="text-on-surface-variant leading-relaxed text-lg">{sections.whatIsGeo.description}</p>
              <p class="text-on-surface-variant leading-relaxed" set:html={sections.whatIsGeo.detail.replace('citations and contextual inclusion', '<span class="font-bold text-primary">citations and contextual inclusion</span>')} />
              <div class="pt-6 space-y-4">
                {sections.whatIsGeo.features?.map((f: any) => (
                  <div class="flex items-start gap-4">
                    <span class="material-symbols-outlined text-primary p-2 bg-white rounded-full shadow-sm">{f.icon}</span>
                    <div>
                      <h4 class="font-headline font-bold text-lg">{f.title}</h4>
                      <p class="text-sm text-on-surface-variant">{f.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Our Expertise -->
    {sections.expertise && (
      <section class="py-32 px-6 max-w-7xl mx-auto">
        <div class="text-center mb-16 space-y-4">
          <h2 class="font-headline text-4xl font-bold tracking-tight">Our Expertise</h2>
          <p class="text-on-surface-variant max-w-xl mx-auto">Proprietary methodologies designed for the generative era.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {sections.expertise.map((card: any, i: number) => {
            if (i === 0) return (
              <div class="md:col-span-2 glass-card p-10 rounded-lg hover:shadow-2xl transition-all group overflow-hidden relative">
                <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-primary/5 rounded-full group-hover:scale-150 transition-transform duration-700"></div>
                <span class="material-symbols-outlined text-primary text-4xl mb-6 block">{card.icon}</span>
                <h3 class="font-headline text-2xl font-bold mb-4">{card.title}</h3>
                <p class="text-on-surface-variant mb-6 max-w-md">{card.description}</p>
                {card.features && (
                  <ul class="font-label text-xs space-y-2 text-primary font-semibold">
                    {card.features.map((f: string) => (
                      <li class="flex items-center gap-2"><span class="material-symbols-outlined text-[14px]">check_circle</span> {f}</li>
                    ))}
                  </ul>
                )}
              </div>
            );
            if (i === 1) return (
              <div class="bg-surface-container-highest p-10 rounded-lg hover:bg-primary hover:text-on-primary transition-all group">
                <span class="material-symbols-outlined text-primary group-hover:text-on-primary text-4xl mb-6 block">{card.icon}</span>
                <h3 class="font-headline text-2xl font-bold mb-4">{card.title}</h3>
                <p class="opacity-80 group-hover:opacity-100 mb-6">{card.description}</p>
                <a class="inline-flex items-center gap-2 font-label text-xs font-bold uppercase tracking-widest border-b border-current pb-1" href="#">Learn More</a>
              </div>
            );
            if (i === 2) return (
              <div class="bg-surface-container-low p-10 rounded-lg border border-outline-variant/10 hover:border-primary/30 transition-all">
                <span class="material-symbols-outlined text-primary text-4xl mb-6 block">{card.icon}</span>
                <h3 class="font-headline text-2xl font-bold mb-4">{card.title}</h3>
                <p class="text-on-surface-variant mb-6">{card.description}</p>
              </div>
            );
            if (i === 3) return (
              <div class="md:col-span-2 glass-card p-10 rounded-lg flex flex-col md:flex-row gap-10 items-center">
                <div class="flex-1">
                  <h3 class="font-headline text-2xl font-bold mb-4">{card.title}</h3>
                  <p class="text-on-surface-variant mb-6">{card.description}</p>
                  <button class="font-label text-xs px-6 py-3 bg-on-surface text-surface rounded-full font-bold">Request Demo</button>
                </div>
                <div class="w-full md:w-64 h-40 bg-white/50 rounded-md border border-outline-variant/20 flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary/20 text-6xl">{card.icon}</span>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Latest AI Guides -->
    {sections.guides && (
      <section class="bg-surface py-24">
        <div class="max-w-7xl mx-auto px-6">
          <div class="flex justify-between items-end mb-12">
            <div class="space-y-2">
              <span class="font-label text-xs font-bold text-primary uppercase tracking-widest">Knowledge Hub</span>
              <h2 class="font-headline text-4xl font-bold tracking-tight">Latest AI Guides</h2>
            </div>
            <a class="hidden md:block font-label text-sm font-bold text-on-surface-variant hover:text-primary transition-colors" href="/blog">View All Resources &rarr;</a>
          </div>
          <div class="space-y-4">
            {sections.guides.map((guide: any) => (
              <a href="/blog" class="group flex flex-col md:flex-row md:items-center justify-between p-8 bg-surface-container-low rounded-lg hover:bg-white hover:shadow-xl transition-all cursor-pointer">
                <div class="flex gap-6 items-center">
                  <span class="font-headline text-3xl font-light text-outline-variant group-hover:text-primary transition-colors">{guide.number}</span>
                  <div>
                    <h4 class="font-headline text-xl font-bold">{guide.title}</h4>
                    <p class="text-sm text-on-surface-variant">{guide.description}</p>
                  </div>
                </div>
                <div class="flex items-center gap-8 mt-4 md:mt-0">
                  <span class="font-label text-[10px] uppercase font-bold text-on-surface-variant/60">{guide.readTime}</span>
                  <span class="material-symbols-outlined text-primary opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0 transition-all">arrow_forward</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    {page?.ctaTitle && page.ctaStyle === 'dark' && (
      <section class="py-24 px-6 max-w-7xl mx-auto">
        <div class="rounded-lg bg-inverse-surface p-12 md:p-20 relative overflow-hidden text-center">
          <div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 blur-[100px]"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-secondary/10 blur-[100px]"></div>
          <div class="relative z-10 space-y-8">
            <h2 class="font-headline text-4xl md:text-5xl font-bold text-surface tracking-tight">{page.ctaTitle}</h2>
            <p class="text-inverse-on-surface max-w-2xl mx-auto text-lg">{page.ctaDescription}</p>
            <div class="flex justify-center">
              <a href={page.ctaButtonLink || '/'} class="bg-primary text-on-primary px-10 py-5 rounded-full font-label font-bold text-sm tracking-wide hover:scale-105 transition-transform">
                {page.ctaButtonText}
              </a>
            </div>
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
